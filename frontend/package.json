{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:admin": "vite --config vite.admin.config.ts",
    "dev:report": "vite --config vite.report.config.ts",
    "build:admin": "tsc -b && vite build --config vite.admin.config.ts",
    "build:report": "tsc -b && vite build --config vite.report.config.ts",
    "build": "npm run build:admin && npm run build:report",
    "lint": "eslint .",
    "preview:admin": "vite preview --config vite.admin.config.ts",
    "preview:report": "vite preview --config vite.report.config.ts"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
